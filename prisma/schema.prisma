generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       String
  imageUrl    String?
  category    String
  gender      String
  sizes       String[]
  createdAt   DateTime @default(now())
}
